@model HotelManagement.Models.Room

@{
    ViewData["Title"] = "Delete Room";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Delete Room @Model.RoomNumber</h1>

            <div class="alert alert-warning" role="alert">
                <strong>Warning!</strong> Are you sure you want to delete this room? This action cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Room Number</th>
                            <td>@Model.RoomNumber</td>
                        </tr>
                        <tr>
                            <th>Room Type</th>
                            <td>@Model.RoomType?.TypeName</td>
                        </tr>
                        <tr>
                            <th>Capacity</th>
                            <td>@Model.Capacity Guests</td>
                        </tr>
                        <tr>
                            <th>Price</th>
                            <td>$@Model.Price.ToString("F2") per night</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>@Model.Status</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="mt-4">
                <form asp-action="DeleteConfirmed" method="post" style="display:inline-block;">
                    <input type="hidden" asp-for="RoomID" />
                    <button type="submit" class="btn btn-danger">Yes, Delete This Room</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
