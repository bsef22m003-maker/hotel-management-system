@model IEnumerable<HotelManagement.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Bookings</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">New Booking</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Booking ID</th>
                        <th>Guest</th>
                        <th>Room</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Total Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td>@booking.BookingID</td>
                            <td>@booking.Guest?.FirstName @booking.Guest?.LastName</td>
                            <td>@booking.Room?.RoomNumber</td>
                            <td>@booking.CheckinDate.ToString("yyyy-MM-dd")</td>
                            <td>@booking.CheckoutDate.ToString("yyyy-MM-dd")</td>
                            <td>$@booking.TotalPrice.ToString("F2")</td>
                            <td>
                                <span class="badge bg-@GetStatusColor(booking.Status)">@booking.Status</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@booking.BookingID" class="btn btn-sm btn-info">View</a>
                                <a asp-action="Edit" asp-route-id="@booking.BookingID" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Cancel" asp-route-id="@booking.BookingID" class="btn btn-sm btn-danger" onclick="return confirm('Cancel this booking?')">Cancel</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No bookings found. <a asp-action="Create">Create a new booking</a>
        </div>
    }
</div>

@functions {
    private string GetStatusColor(HotelManagement.Models.BookingStatus status)
    {
        return status switch
        {
            HotelManagement.Models.BookingStatus.Pending => "warning",
            HotelManagement.Models.BookingStatus.Confirmed => "info",
            HotelManagement.Models.BookingStatus.CheckedIn => "success",
            HotelManagement.Models.BookingStatus.CheckedOut => "secondary",
            HotelManagement.Models.BookingStatus.Cancelled => "danger",
            _ => "secondary"
        };
    }
}
