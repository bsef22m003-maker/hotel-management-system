@model HotelManagement.Models.Booking

@{
    ViewData["Title"] = "Booking Details";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Booking Details - #@Model.BookingID</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Edit" asp-route-id="@Model.BookingID" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Booking Information</h5>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Booking ID</th>
                            <td>@Model.BookingID</td>
                        </tr>
                        <tr>
                            <th>Guest Name</th>
                            <td>@Model.Guest?.FirstName @Model.Guest?.LastName</td>
                        </tr>
                        <tr>
                            <th>Guest Email</th>
                            <td>@Model.Guest?.Email</td>
                        </tr>
                        <tr>
                            <th>Guest Phone</th>
                            <td>@Model.Guest?.Phone</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header bg-info text-white">
                    <h5>Room Information</h5>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Room Number</th>
                            <td>@Model.Room?.RoomNumber</td>
                        </tr>
                        <tr>
                            <th>Room Type</th>
                            <td>@Model.Room?.RoomType?.TypeName</td>
                        </tr>
                        <tr>
                            <th>Capacity</th>
                            <td>@Model.Room?.Capacity Guests</td>
                        </tr>
                        <tr>
                            <th>Price per Night</th>
                            <td>$@Model.Room?.Price.ToString("F2")</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header bg-success text-white">
                    <h5>Booking Dates & Payment</h5>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Check-in Date</th>
                            <td>@Model.CheckinDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                        <tr>
                            <th>Check-out Date</th>
                            <td>@Model.CheckoutDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                        <tr>
                            <th>Number of Nights</th>
                            <td>@((Model.CheckoutDate - Model.CheckinDate).Days) nights</td>
                        </tr>
                        <tr>
                            <th>Total Price</th>
                            <td><strong>$@Model.TotalPrice.ToString("F2")</strong></td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>
                                <span class="badge bg-@GetStatusColor(Model.Status)">@Model.Status</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Special Requests</th>
                            <td>@(string.IsNullOrEmpty(Model.SpecialRequests) ? "None" : Model.SpecialRequests)</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="mt-4">
                @if (Model.Status.ToString() == "Pending" || Model.Status.ToString() == "Confirmed")
                {
                    <a asp-controller="Payment" asp-action="Create" asp-route-bookingId="@Model.BookingID" 
                       class="btn btn-success">Process Payment</a>
                }
                <a asp-action="Index" class="btn btn-secondary">Back to Bookings</a>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetStatusColor(HotelManagement.Models.BookingStatus status)
    {
        return status switch
        {
            HotelManagement.Models.BookingStatus.Pending => "warning",
            HotelManagement.Models.BookingStatus.Confirmed => "info",
            HotelManagement.Models.BookingStatus.CheckedIn => "success",
            HotelManagement.Models.BookingStatus.CheckedOut => "secondary",
            HotelManagement.Models.BookingStatus.Cancelled => "danger",
            _ => "secondary"
        };
    }
}
