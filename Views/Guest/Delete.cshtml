@model HotelManagement.Models.Guest

@{
    ViewData["Title"] = "Delete Guest";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Delete Guest</h1>

            <div class="alert alert-warning" role="alert">
                <strong>Warning!</strong> Are you sure you want to delete this guest? This action cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Name</th>
                            <td>@Model.FirstName @Model.LastName</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <th>Phone</th>
                            <td>@Model.Phone</td>
                        </tr>
                        <tr>
                            <th>City</th>
                            <td>@Model.City</td>
                        </tr>
                        <tr>
                            <th>Total Bookings</th>
                            <td>@(Model.Bookings?.Count() ?? 0)</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="mt-4">
                <form asp-action="DeleteConfirmed" method="post" style="display:inline-block;">
                    <input type="hidden" asp-for="GuestID" />
                    <button type="submit" class="btn btn-danger">Yes, Delete This Guest</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
